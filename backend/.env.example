# PressureLab AI - Environment Configuration

# IBM Granite (Hugging Face)
HF_API_KEY=hf_your_api_key_here
GRANITE_MODEL_ID=ibm-granite/granite-3.3-8b-instruct

# IBM watsonx.ai (optional - alternative provider)
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# LLM Provider: "huggingface" or "watsonx"
LLM_PROVIDER=huggingface

# Database
DATABASE_URL=postgresql://pressurelab:pressurelab@localhost:5432/pressurelab
DATABASE_FALLBACK_URL=sqlite:///./pressurelab.db

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# Langflow
LANGFLOW_URL=http://localhost:7860
LANGFLOW_API_KEY=

# Application
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
